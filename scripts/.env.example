# XVideos Go Backend 环境变量配置
# 复制此文件为 .env 并修改对应值

# ==================== 服务器配置 ====================

# 服务监听端口（UFW 已限制仅 CF IP 可访问）
SERVER_PORT=8080
SERVER_MODE=release

# ==================== 数据库配置 ====================

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=videosgo
DB_PASSWORD=your_secure_password_here
DB_NAME=videosgo
DB_SSLMODE=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=3600

# ==================== Redis 配置 ====================

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== JWT 认证 ====================

JWT_SECRET=your_jwt_secret_change_this_to_random_string
JWT_EXPIRE_HOURS=168

# ==================== XOR 加密密钥 ====================

CRYPTO_KEY=XVideos2024SecretKey

# ==================== 采集配置 ====================

# 采集 Worker 数量（建议 CPU 核数 * 2）
COLLECTOR_WORKERS=8

# m3u8 存活探测超时（秒）
M3U8_PROBE_TIMEOUT=10

# 采集间隔（分钟）
COLLECT_INTERVAL=30

# ==================== Cloudflare 配置 ====================

# 前端域名（用于 CORS 白名单）
CORS_ORIGINS=https://xvideos.com,https://xvideos1.com

# ==================== Telegram Bot ====================

TG_BOT_TOKEN=
TG_WEBHOOK_SECRET=

# ==================== 推送通知 ====================

PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:admin@xvideos.com

# ==================== 日志配置 ====================

LOG_LEVEL=info
LOG_FILE=/opt/videosgo/logs/videosgo.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30

# ==================== 站群配置 ====================

# A 队（质量站，20个域名）
CLUSTER_A_DOMAINS=xvideos.com,xvideos1.com

# B 队（流量站，80个域名）
CLUSTER_B_DOMAINS=xvideos2.com,xvideos3.com,xvideos4.com

# ==================== GitHub Gist（域名漂移） ====================

DOMAIN_GIST_ID=
DOMAIN_GIST_TOKEN=

# ==================== Telegram Bot ====================
TG_BOT_TOKEN=
TG_WEBHOOK_URL=

# ==================== Web Push VAPID ====================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@xvideos.com

# ==================== 支付配置 ====================
PAYMENT_DEFAULT_CHANNEL=crypto
PAYMENT_ORDER_EXPIRE_SEC=1800

# ==================== 域名轮换 ====================
DOMAIN_CHECK_INTERVAL_SEC=60
DOMAIN_DEFAULT_REGION=global
