# ===========================================
# videosgo 环境变量配置模板
# ===========================================

# 服务配置
APP_ENV=development
APP_PORT=8080
APP_SECRET=your-secret-key-change-in-production

# 数据库配置 (PostgreSQL 18)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=videosgo
DB_SSLMODE=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRE_HOURS=72

# 加密配置 (XOR 密钥，用于 m3u8 链接混淆)
CRYPTO_KEY=your-crypto-key-16byte

# 采集器配置
COLLECTOR_WORKERS=10
COLLECTOR_RETRY_MAX=3
COLLECTOR_PROBE_TIMEOUT=2s

# 安全配置
# CORS 允许的域名，逗号分隔，支持通配符 *
CORS_ALLOWED_ORIGINS=*
# UA 白名单路径（逗号分隔），这些路径不检查 UA
UA_WHITELIST_PATHS=/api/v1/health,/api/v1/ping
# 是否启用 UA 过滤（仅允许移动端）
UA_FILTER_ENABLED=false
# 是否启用 WAF
WAF_ENABLED=true
# 限流配置（每分钟请求数）
RATE_LIMIT_PER_MINUTE=60

# 日志级别: debug, info, warn, error
LOG_LEVEL=debug
