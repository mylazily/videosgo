# 应用配置
APP_ENV=production
APP_PORT=8080
APP_SECRET=change-me-in-production-min-32-chars

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=videosgo
DB_PASSWORD=your-secure-password
DB_NAME=videosgo
DB_SSLMODE=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_EXPIRE_HOURS=72

# CORS 配置
CORS_ALLOWED_ORIGINS=*

# 日志配置
LOG_LEVEL=info
