# ============================================================
# VideosGo 环境变量配置示例
# 复制此文件为 .env 并修改相应配置
# ============================================================

# 应用配置
APP_ENV=production
APP_PORT=8080
APP_SECRET=your-random-secret-key-here-minimum-32-characters

# 数据库配置 (PostgreSQL 18.x)
DB_HOST=localhost
DB_PORT=5432
DB_USER=videos
DB_PASSWORD=your-secure-password
DB_NAME=videosdb
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# JWT 配置
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h

# CORS 配置
CORS_ALLOWED_ORIGINS=https://901.555554.xyz,https://*.pages.dev

# 安全设置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# 日志设置
LOG_LEVEL=info
LOG_FORMAT=json

# Telegram 通知（可选）
TG_BOT_TOKEN=your-bot-token
TG_ADMIN_USER_IDS=your-telegram-id

# 监控（可选）
METRICS_ENABLED=true
METRICS_PORT=9090
